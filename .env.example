# ── Required: Convex Backend ───────────────────────────────────────────────
# Create a free account at https://convex.dev and deploy to get your URL
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# ── Required: Hercules Auth (OIDC) ─────────────────────────────────────────
# Set up an app at https://hercules-auth.com and get these values
VITE_HERCULES_OIDC_AUTHORITY=https://your-app-id.hercules-auth.com
VITE_HERCULES_OIDC_CLIENT_ID=your-client-id

# ── Optional: Customize ────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
HERCULES_API_KEY=hrc_...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
